{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "http://localhost:5115",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "https://localhost:7144;http://localhost:5115",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "Full Stack": {
      "commandName": "Executable",
      "executablePath": "pwsh",
      "commandLineArgs": "-NoExit -File \"run-fullstack.ps1\"",
      "workingDirectory": "$(ProjectDir)..",
      "launchBrowser": true,
      "launchUrl": "http://localhost:5173"
    }
  }
}
